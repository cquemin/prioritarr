<configuration>
  <!-- Match the python log format: single-line JSON with ts|level|logger|msg. -->
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp><fieldName>ts</fieldName><pattern>yyyy-MM-dd HH:mm:ss,SSS</pattern></timestamp>
        <logLevel><fieldName>level</fieldName></logLevel>
        <loggerName><fieldName>logger</fieldName></loggerName>
        <message><fieldName>msg</fieldName></message>
        <stackTrace><fieldName>stack</fieldName></stackTrace>
      </providers>
    </encoder>
  </appender>
  <root level="INFO">
    <appender-ref ref="STDOUT" />
  </root>
  <!-- Quiet the noisy libs at INFO but let INFO+ through elsewhere. -->
  <logger name="io.netty" level="WARN"/>
  <logger name="io.ktor" level="INFO"/>
</configuration>
