{
  "components": {
    "schemas": {
      "ActionResult": {
        "properties": {
          "dryRun": {
            "type": "boolean"
          },
          "message": {
            "nullable": true,
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "title": "ActionResult",
        "type": "object"
      },
      "DependencyStatus": {
        "enum": [
          "ok",
          "unreachable"
        ],
        "title": "DependencyStatus",
        "type": "string"
      },
      "HealthOk": {
        "examples": [
          {
            "status": "ok"
          }
        ],
        "properties": {
          "status": {
            "const": "ok",
            "default": "ok",
            "description": "Always 'ok' when healthy.",
            "title": "Status",
            "type": "string"
          }
        },
        "title": "HealthOk",
        "type": "object"
      },
      "HealthProvidersResponse": {
        "properties": {
          "providers": {
            "items": {
              "$ref": "#/components/schemas/ProviderHealthEntry"
            },
            "title": "Providers",
            "type": "array"
          }
        },
        "required": [
          "providers"
        ],
        "title": "HealthProvidersResponse",
        "type": "object"
      },
      "HealthUnhealthy": {
        "examples": [
          {
            "reason": "heartbeat_stale: 342s > 300s",
            "status": "unhealthy"
          }
        ],
        "properties": {
          "reason": {
            "description": "Human-readable diagnostic. Free-form text.",
            "title": "Reason",
            "type": "string"
          },
          "status": {
            "const": "unhealthy",
            "default": "unhealthy",
            "description": "Always 'unhealthy'.",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "title": "HealthUnhealthy",
        "type": "object"
      },
      "OnGrabDuplicate": {
        "properties": {
          "label": {
            "title": "Label",
            "type": "string"
          },
          "priority": {
            "maximum": 5,
            "minimum": 1,
            "title": "Priority",
            "type": "integer"
          },
          "status": {
            "const": "duplicate",
            "default": "duplicate",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "priority",
          "label"
        ],
        "title": "OnGrabDuplicate",
        "type": "object"
      },
      "OnGrabIgnored": {
        "properties": {
          "eventType": {
            "description": "The eventType value that was ignored, echoed verbatim.",
            "title": "Eventtype",
            "type": "string"
          },
          "status": {
            "const": "ignored",
            "default": "ignored",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "eventType"
        ],
        "title": "OnGrabIgnored",
        "type": "object"
      },
      "OnGrabProcessed": {
        "properties": {
          "label": {
            "description": "Human-readable label like 'P1 Live-following'.",
            "title": "Label",
            "type": "string"
          },
          "priority": {
            "description": "Computed priority 1 (highest) through 5 (lowest).",
            "maximum": 5,
            "minimum": 1,
            "title": "Priority",
            "type": "integer"
          },
          "status": {
            "const": "processed",
            "default": "processed",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "priority",
          "label"
        ],
        "title": "OnGrabProcessed",
        "type": "object"
      },
      "PaginatedEnvelope": {
        "properties": {
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "records": {
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "totalRecords": {
            "type": "integer"
          }
        },
        "required": [
          "records",
          "totalRecords",
          "offset",
          "limit"
        ],
        "title": "PaginatedEnvelope",
        "type": "object"
      },
      "PlexEventOk": {
        "properties": {
          "series_id": {
            "description": "The Sonarr seriesId the event was applied to.",
            "title": "Series Id",
            "type": "integer"
          },
          "status": {
            "const": "ok",
            "default": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "series_id"
        ],
        "title": "PlexEventOk",
        "type": "object"
      },
      "PlexEventUnmatched": {
        "properties": {
          "plex_key": {
            "description": "The grandparent_rating_key we couldn't map.",
            "title": "Plex Key",
            "type": "string"
          },
          "status": {
            "const": "unmatched",
            "default": "unmatched",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "plex_key"
        ],
        "title": "PlexEventUnmatched",
        "type": "object"
      },
      "ProblemDetail": {
        "properties": {
          "detail": {
            "type": "string"
          },
          "instance": {
            "nullable": true,
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "title": "ProblemDetail",
        "type": "object"
      },
      "ProviderHealthEntry": {
        "properties": {
          "detail": {
            "description": "One-line diagnostic surfaced under the banner row. Truncated to ~500 chars.",
            "nullable": true,
            "title": "Detail",
            "type": "string"
          },
          "label": {
            "description": "Human-readable provider name shown in the banner.",
            "title": "Label",
            "type": "string"
          },
          "lastCheckAt": {
            "description": "ISO-8601 of the most recent probe attempt.",
            "title": "LastCheckAt",
            "type": "string"
          },
          "lastOkAt": {
            "description": "ISO-8601 of the last successful probe; null if never seen healthy.",
            "nullable": true,
            "title": "LastOkAt",
            "type": "string"
          },
          "name": {
            "description": "Stable provider id (e.g. 'sonarr', 'plex').",
            "title": "Name",
            "type": "string"
          },
          "settingsAnchor": {
            "description": "Hash anchor in /settings to deep-link the user to the matching detail view.",
            "title": "SettingsAnchor",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ProviderStatus"
          }
        },
        "required": [
          "name",
          "label",
          "status",
          "settingsAnchor",
          "lastCheckAt"
        ],
        "title": "ProviderHealthEntry",
        "type": "object"
      },
      "ProviderStatus": {
        "enum": [
          "ok",
          "unauth",
          "unreachable",
          "unknown"
        ],
        "title": "ProviderStatus",
        "type": "string"
      },
      "ReadyResponse": {
        "examples": [
          {
            "dependencies": {
              "qbit": "ok",
              "sab": "ok",
              "sonarr": "ok",
              "tautulli": "ok"
            },
            "last_heartbeat": "2026-04-14T22:30:00.123456+00:00",
            "status": "ok"
          }
        ],
        "properties": {
          "dependencies": {
            "additionalProperties": {
              "$ref": "#/components/schemas/DependencyStatus"
            },
            "description": "Status of each upstream dependency.",
            "propertyNames": {
              "enum": [
                "sonarr",
                "tautulli",
                "qbit",
                "sab"
              ]
            },
            "title": "Dependencies",
            "type": "object"
          },
          "last_heartbeat": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Most recent scheduler heartbeat. ISO 8601 with +00:00 offset. Null if never run.",
            "title": "Last Heartbeat"
          },
          "status": {
            "description": "'ok' iff every dependency is 'ok', else 'degraded'.",
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "dependencies",
          "last_heartbeat"
        ],
        "title": "ReadyResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "api_key": {
        "in": "header",
        "name": "X-Api-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Priority-aware download queue orchestrator. See https://github.com/cquemin/prioritarr",
    "title": "Prioritarr API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/plex-event": {
      "post": {
        "description": "Accepts Tautulli's 'watched' notification. Always returns HTTP 200. Triggers a synchronous mapping refresh if the plex_key is unknown (legacy quirk #5). Returns 'ok' when the priority cache was invalidated for a known series, 'unmatched' otherwise.",
        "operationId": "plex_event_api_plex_event_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/PlexEventOk"
                    },
                    {
                      "$ref": "#/components/schemas/PlexEventUnmatched"
                    }
                  ]
                }
              }
            },
            "description": "Webhook accepted (one of two shapes)."
          }
        },
        "summary": "Tautulli watched notification"
      }
    },
    "/api/sonarr/on-grab": {
      "post": {
        "description": "Always returns HTTP 200. Response shape depends on outcome.",
        "operationId": "sonarr_on_grab_api_sonarr_on_grab_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/OnGrabIgnored"
                    },
                    {
                      "$ref": "#/components/schemas/OnGrabProcessed"
                    },
                    {
                      "$ref": "#/components/schemas/OnGrabDuplicate"
                    }
                  ]
                }
              }
            },
            "description": "Webhook accepted"
          }
        },
        "summary": "Sonarr OnGrab webhook receiver"
      }
    },
    "/api/v2/audit": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "series_id",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "action",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "since",
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 50,
              "maximum": 1000,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "sort_dir",
            "schema": {
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedEnvelope"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Validation"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "List audit log entries (paginated; filter by series_id/action/since)"
      }
    },
    "/api/v2/downloads": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "client",
            "schema": {
              "enum": [
                "qbit",
                "sab"
              ],
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 50,
              "maximum": 1000,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "sort_dir",
            "schema": {
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedEnvelope"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Validation"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "List managed downloads (paginated; filter by client)"
      }
    },
    "/api/v2/downloads/{client}/{clientId}": {
      "delete": {
        "parameters": [
          {
            "in": "path",
            "name": "client",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResult"
                }
              }
            },
            "description": "Untracked"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Not found"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Untrack a managed download"
      },
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "client",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "ManagedDownload",
                  "type": "object"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Validation"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Get managed download detail"
      }
    },
    "/api/v2/downloads/{client}/{clientId}/actions/{action}": {
      "post": {
        "parameters": [
          {
            "in": "path",
            "name": "client",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "action",
            "required": true,
            "schema": {
              "enum": [
                "pause",
                "resume",
                "boost",
                "demote"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResult"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Not found"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Validation"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          },
          "502": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Upstream unreachable"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Pause / resume / boost / demote a tracked download"
      }
    },
    "/api/v2/events": {
      "get": {
        "parameters": [
          {
            "in": "header",
            "name": "Last-Event-ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "lastEventId",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Event stream"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Server-Sent Events stream"
      }
    },
    "/api/v2/health/providers": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthProvidersResponse"
                }
              }
            },
            "description": "Snapshot of every probed upstream's status."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Provider health snapshot — powers the dashboard banner"
      }
    },
    "/api/v2/mappings": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "MappingSnapshot",
                  "type": "object"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Validation"
          },
          "500": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ],
        "summary": "Plex\u2194Sonarr mapping snapshot"
      }
    },
    "/api/v2/mappings/refresh": {
      "post": {
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResult"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Not found"
          },
          "422": {
            "content": {
